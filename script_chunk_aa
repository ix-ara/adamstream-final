        }

        const absoluteEpisode = Number(episode) || 1;
        const mapped = currentAnimeMap[absoluteEpisode - 1];
        return {
            season: mapped ? mapped.season : (Number(season) || 1),
            episode: mapped ? mapped.episode : absoluteEpisode,
            absoluteEpisode
        };
    }

